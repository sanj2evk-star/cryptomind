# ============================================================
# Frontend Environment Variables
# Copy this file to .env.local:  cp .env.example .env.local
# Vite loads .env.local automatically in dev mode.
# ============================================================

# --- Backend API URL ---
# Must match the running backend. No trailing slash.
# Local development:
VITE_API_URL=http://localhost:8000
# Production (replace with your deployed backend):
# VITE_API_URL=https://your-backend.railway.app

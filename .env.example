# ============================================================
# Backend Environment Variables
# Copy this file to .env:  cp .env.example .env
# ============================================================

# --- Claude API (optional for UI, required for live trading) ---
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Model to use for trading decisions
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Authentication ---
# Default login credentials (change in production)
API_USERNAME=admin
API_PASSWORD=changeme
# Secret for signing JWT tokens (auto-generated if empty)
JWT_SECRET=

# --- CORS ---
# Frontend origin(s), comma-separated. Backend always allows localhost:3000.
CORS_ORIGINS=http://localhost:3000

# --- Telegram Alerts (optional) ---
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
